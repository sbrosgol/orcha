# Orcha configuration example.
# Copy to orcha.yaml (or config/orcha.yaml) and edit. Any value can be
# overridden by an environment variable, e.g. ORCHA_ADMIN_PASSWORD.

server:
  host: "0.0.0.0"
  port: 8070
  worker_threads: 4

logging:
  file: "./logs/orcha.log"
  level: INFO
  console_output: true

plugins:
  directory: "./commands"
  auto_reload: false
  scan_interval_ms: 5000
  denylist_path: "./orcha-disabled-plugins.txt"   # plugins disabled via the admin UI

# Admin dashboard (/admin) and admin API (/api/plugins).
admin:
  enabled: true
  auth_required: true
  username: "admin"
  # The admin surface is DISABLED unless a password is set (fail closed) while
  # auth_required is true. Set it here or via ORCHA_ADMIN_PASSWORD.
  password: "change-me"
  realm: "Orcha Admin"

# Jobs: saved workflows + run history (SQLite-backed) + cron scheduler.
jobs:
  db_path: "./orcha-jobs.db"
  scheduler_enabled: true       # run due jobs (schedule_cron) on a timer
  scheduler_tick_seconds: 30    # how often the scheduler checks (< 60)
